{
  "name": "calculator-mcp-server",
  "version": "1.0.0",
  "description": "Calculator MCP server (add/subtract/multiply/divide) using the official MCP SDK",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc && tsx server.ts",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx server.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.1",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
